# Auto detect text files and perform LF normalization
* text=auto

# Markdown - prefer LF for consistency across editors
*.md text eol=lf

# Shell scripts
*.sh text eol=lf

# Batch/PowerShell
*.bat text eol=crlf
*.ps1 text eol=crlf

# Binary files - detect
*.png binary
*.jpg binary
*.ico binary
*.zip binary
